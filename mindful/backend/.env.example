# --- Core ---
PORT=4000
NODE_ENV=development

# --- Postgres (runs in the same docker-compose stack, free) ---
DATABASE_URL=postgres://mindful:mindful@postgres:5432/mindful

# --- Redis (same stack, free) ---
REDIS_URL=redis://redis:6379

# --- LLM for TLDR + YouTube summaries ---
# Google Gemini free tier: 15 RPM, 1500 RPD, 1M tokens/day.
# Grab a key (free) at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- YouTube Data API v3 (free, 10k units/day) ---
# Create at https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=

# --- Twitter (in-process scraper, no separate container) ---
# Extract these from your browser after logging into x.com — see
# DEPLOY.md "Twitter cookie setup" for the 5-minute walkthrough.
# Required: TWITTER_AUTH_TOKEN, TWITTER_CT0.
# Optional but recommended: TWITTER_KDT, TWITTER_GUEST_ID.
# If left blank, the Twitter worker logs a warning and skips polling.
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
TWITTER_KDT=
TWITTER_GUEST_ID=

# --- IMAP for newsletter ingestion ---
# Use a free dedicated Gmail account; see README "Newsletter setup".
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_TLS=true

# --- Polling cadence (seconds) ---
# Lower = more real-time but more API/scraper load. Defaults are conservative
# enough to fit free tiers and avoid Twitter rate-limiting your cookie.
RSS_POLL_INTERVAL=300        # 5 min
YOUTUBE_POLL_INTERVAL=900    # 15 min
TWITTER_POLL_INTERVAL=1200   # 20 min
