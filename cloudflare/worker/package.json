{
  "name": "tsundoku-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "migrate:remote": "wrangler d1 execute tsundoku --remote --file=migrations/0001_init.sql",
    "migrate:local":  "wrangler d1 execute tsundoku --local  --file=migrations/0001_init.sql",
    "seed:remote":    "wrangler d1 execute tsundoku --remote --file=migrations/0002_seed.sql",
    "seed:local":     "wrangler d1 execute tsundoku --local  --file=migrations/0002_seed.sql",
    "migrate:prefs":  "wrangler d1 execute tsundoku --remote --file=migrations/0003_prefs.sql",
    "migrate:v1_1":   "wrangler d1 execute tsundoku --remote --file=migrations/0004_v1_1.sql",
    "migrate:v1_3":   "wrangler d1 execute tsundoku --remote --file=migrations/0005_v1_3.sql",
    "backup:remote":  "wrangler d1 export tsundoku --remote --output=backups/tsundoku-$(date +%Y%m%d-%H%M%S).sql"
  },
  "devDependencies": {
    "wrangler": "^3.78.0"
  }
}
