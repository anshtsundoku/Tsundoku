# Build outputs. The extension download (tsundoku-extension.zip) and
# extension-version.json are emitted into dist/ by the extensionZip Vite plugin
# on every build (see vite-plugin-extension-zip.js); dist/ is ignored wholesale.
dist/

# Legacy location from the old shell-zip script — no longer generated, but keep
# ignored so a stale local copy never gets committed.
public/tsundoku-extension.zip
public/extension-version.json
