{
  "manifest_version": 3,
  "name": "Tsundoku — X sync",
  "version": "0.1.0",
  "description": "One-click x.com cookie sync for Tsundoku.",
  "permissions": ["cookies", "storage", "alarms"],
  "host_permissions": [
    "https://x.com/*",
    "https://*.x.com/*",
    "https://tsundoku-e0v.pages.dev/*",
    "https://tsundoku-api.ansh-tsundoku.workers.dev/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png" }
  },
  "content_scripts": [{
    "matches": ["https://tsundoku-e0v.pages.dev/extension-pair*"],
    "js": ["pair.js"],
    "run_at": "document_idle"
  }],
  "web_accessible_resources": [{
    "resources": ["inject.js"],
    "matches": ["https://tsundoku-e0v.pages.dev/*"]
  }],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
